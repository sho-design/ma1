---
import Base from '@layouts/Base.astro';
import TreatmentCard from '@components/TreatmentCard.astro';
import BeforeAfter from '@components/BeforeAfter.astro';
import { treatments, treatmentsByFamily, type Treatment } from '@data/treatments';
import { familyBySlug } from '@data/families';
import { modalities } from '@data/modalities';
import { concerns } from '@data/concerns';
import { careByFamily, sharedFaqs } from '@data/care';
import { protocolsByTreatment } from '@data/protocols';
import { site } from '@data/site';

export function getStaticPaths() {
  return treatments.map((t) => ({ params: { slug: t.slug }, props: { treatment: t } }));
}

interface Props { treatment: Treatment; }
const { treatment } = Astro.props;
const fam = familyBySlug(treatment.family);
const av = fam?.accentVar ?? 'injectables';
const accent = `--accent: var(--accent-${av}); --accent-text: var(--accent-${av}-text); --accent-vivid: var(--accent-${av}-vivid)`;

const acts = modalities.filter((m) => treatment.actives.includes(m.slug));
const supports = [...new Set(acts.map((m) => m.maySupport))];
const whatItIs = acts.map((m) => m.essence).join(' ') || treatment.essence;
const relatedConcerns = concerns.filter((c) => treatment.concerns.includes(c.slug));
const related = treatmentsByFamily(treatment.family).filter((t) => t.slug !== treatment.slug).slice(0, 3);

const care = careByFamily[treatment.family];
const faqs = [...care.faqs, ...sharedFaqs];
const protos = protocolsByTreatment(treatment.slug);

const crumbs = [
  { name: 'Home', url: `${site.url}/` },
  { name: 'Treatments', url: `${site.url}/treatments` },
  { name: treatment.name, url: `${site.url}/treatments/${treatment.slug}` },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MedicalProcedure',
  name: treatment.name,
  description: treatment.essence,
  url: `${site.url}/treatments/${treatment.slug}`,
  provider: {
    '@type': 'MedicalClinic',
    name: `${site.line} at ${site.brand}`,
    areaServed: site.locations.map((l) => l.city),
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    item: c.url,
  })),
};
---
<Base title={treatment.name} description={`${treatment.name}: ${treatment.essence}`}>
  <article class="detail" style={accent}>
    <header class="detail__head reveal">
      <div class="wrap">
        <nav class="crumbs" aria-label="Breadcrumb">
          <ol>
            {crumbs.map((c, i) => (
              <li>
                {i < crumbs.length - 1
                  ? <a href={c.url.replace(site.url, '') || '/'}>{c.name}</a>
                  : <span aria-current="page">{c.name}</span>}
              </li>
            ))}
          </ol>
        </nav>
        <p class="eyebrow detail__eyebrow">
          <span class="detail__dot" aria-hidden="true"></span>
          {fam?.name}{treatment.brand && <> · {treatment.brand}</>}
        </p>
        <h1 class="detail__title ripple">{treatment.name}</h1>
        <p class="lede detail__essence">{treatment.essence}</p>

        <dl class="facts">
          <div class="facts__tile"><dt>Downtime</dt><dd>{care.facts.downtime}</dd></div>
          <div class="facts__tile"><dt>Sessions</dt><dd>{care.facts.sessions}</dd></div>
          <div class="facts__tile"><dt>Results</dt><dd>{care.facts.results}</dd></div>
        </dl>
      </div>
    </header>

    <div class="wrap detail__grid">
      <div class="detail__main">
        <section class="reveal detail__block">
          <h2 class="detail__h">What it is</h2>
          <p class="detail__p measure">{whatItIs}</p>
        </section>

        {supports.length > 0 && (
          <section class="reveal detail__block">
            <h2 class="detail__h">Designed to support</h2>
            <ul class="supports">
              {supports.map((s) => (
                <li class="supports__item"><span class="supports__tick" aria-hidden="true"></span>{s}</li>
              ))}
            </ul>
          </section>
        )}

        {relatedConcerns.length > 0 && (
          <section class="reveal detail__block">
            <h2 class="detail__h">What it helps with</h2>
            <div class="help-chips">
              {relatedConcerns.map((c) => (
                <a class="help-chip" href={`/concerns/${c.slug}`} style={`--accent: var(--accent-${c.accent}-vivid)`}>
                  <span class="help-chip__dot" aria-hidden="true"></span>{c.label}
                </a>
              ))}
            </div>
          </section>
        )}

        {protos.length > 0 && (
          <section class="reveal detail__block">
            <h2 class="detail__h">Part of these protocols</h2>
            <p class="detail__p measure" style="margin-bottom:1rem">Combined with other treatments, {treatment.name} is part of these curated courses.</p>
            <div class="help-chips">
              {protos.map((p) => (
                <a class="help-chip" href={`/protocols/${p.slug}`}>
                  <span class="help-chip__dot" aria-hidden="true"></span>{p.name}
                </a>
              ))}
            </div>
          </section>
        )}

        {acts.length > 0 && (
          <section class="reveal detail__block">
            <p class="eyebrow ix__heading">What does the work</p>
            <ul class="ix__list">
              {acts.map((m) => (
                <li>
                  <a class="ix" href={`/modalities#${m.slug}`}>
                    <span class="ix__dot" aria-hidden="true"></span>
                    <span class="ix__name">{m.name}</span>
                    <span class="ix__line">{m.essence}</span>
                  </a>
                </li>
              ))}
            </ul>
            <p class="ix__note meta">Each active is held to an honest, evidence-rated standard. A consult and screening confirm what is right for you.</p>
          </section>
        )}

        {treatment.variants && (
          <section class="reveal detail__block">
            <h2 class="detail__h">Options</h2>
            <ul class="opts">
              {treatment.variants.map((v) => (
                <li class="opts__row">
                  <span class="opts__label">{v.label}{v.note && <span class="opts__note">{v.note}</span>}</span>
                  {v.time && <span class="meta">{v.time}</span>}
                </li>
              ))}
            </ul>
          </section>
        )}

        <section class="reveal detail__block">
          <h2 class="detail__h">What to expect</h2>
          <p class="detail__p measure">
            We confirm the right approach at your complimentary consult.
            {treatment.series && <> {treatment.series}</>}
            {acts[0] && <> Downtime: {acts[0].downtime}</>}
          </p>
        </section>

        <section class="reveal detail__block">
          <h2 class="detail__h">Who it's for</h2>
          <div class="cand">
            <div class="cand__col">
              <p class="cand__label cand__label--yes">A good fit if</p>
              <ul class="supports">
                {care.goodFor.map((g) => (
                  <li class="supports__item"><span class="supports__tick" aria-hidden="true"></span>{g}</li>
                ))}
              </ul>
            </div>
            <div class="cand__col">
              <p class="cand__label cand__label--wait">When we would wait</p>
              <ul class="supports cand__wait">
                {care.notNow.map((n) => (
                  <li class="supports__item"><span class="supports__tick" aria-hidden="true"></span>{n}</li>
                ))}
              </ul>
            </div>
          </div>
          <p class="meta cand__note">Screening at your consult is how we confirm candidacy. This is guidance, not a diagnosis.</p>
        </section>

        <section class="reveal detail__block">
          <h2 class="detail__h">Before your visit</h2>
          <ul class="supports">
            {care.pre.map((p) => (
              <li class="supports__item"><span class="supports__tick" aria-hidden="true"></span>{p}</li>
            ))}
          </ul>
        </section>

        <section class="reveal detail__block">
          <h2 class="detail__h">Aftercare</h2>
          <ul class="supports">
            {care.post.map((p) => (
              <li class="supports__item"><span class="supports__tick" aria-hidden="true"></span>{p}</li>
            ))}
          </ul>
        </section>

        <BeforeAfter name={treatment.name} />

        <section class="reveal detail__block">
          <h2 class="detail__h">Frequently asked</h2>
          <div class="faqs">
            {faqs.map((f) => (
              <details class="faq">
                <summary>{f.q}</summary>
                <p class="faq__a">{f.a}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="reveal detail__block detail__note">
          <h2 class="detail__h">Good to know</h2>
          <p class="detail__p measure">
            We describe what {treatment.name} may support, never a guaranteed
            outcome. It is an elective medical service, delivered under physician
            supervision. Results vary and are confirmed in person.
          </p>
        </section>
      </div>

      <aside class="detail__side reveal">
        <div class="sidecard">
          <p class="eyebrow">Begin</p>
          <p class="sidecard__line">A consult confirms this is right for you.</p>
          {relatedConcerns.length > 0 && (
            <fieldset class="sidecard__goals" data-helps>
              <legend class="meta">What would you like to address?</legend>
              <div class="goals__items">
                {relatedConcerns.map((c) => (
                  <label class="goal-chip">
                    <input type="checkbox" name="goal" value={c.label} checked />
                    <span>{c.label}</span>
                  </label>
                ))}
              </div>
            </fieldset>
          )}
          <a class="btn sidecard__cta" data-book data-tx={treatment.name} href="/contact">Book a consult</a>
          <a class="link-arrow" href="/candidacy">Is this right for me? &rarr;</a>
          <p class="sidecard__member meta">Regulars can save with a <a href="/memberships">membership</a>. We will walk you through it at your consult.</p>
        </div>
      </aside>
    </div>

    <script is:inline define:vars={{ tx: treatment.name }}>
      (function () {
        const btn = document.querySelector('[data-book]');
        const helps = document.querySelector('[data-helps]');
        if (!btn) return;
        const build = () => {
          const goals = Array.from(
            document.querySelectorAll('[data-helps] input[name="goal"]:checked')
          ).map((i) => i.value);
          const p = new URLSearchParams();
          p.set('tx', tx);
          if (goals.length) p.set('goals', goals.join('|'));
          btn.setAttribute('href', '/contact?' + p.toString());
        };
        helps && helps.addEventListener('change', build);
        build();
      })();
    </script>

    {related.length > 0 && (
      <section class="section-tight fill">
        <div class="wrap">
          <div class="reveal sec-head">
            <p class="eyebrow">{fam?.name}</p>
            <h2 class="detail__related-h">Often chosen together.</h2>
          </div>
          <div class="related reveal">
            {related.map((t) => <TreatmentCard treatment={t} />)}
          </div>
        </div>
      </section>
    )}
    <div class="bookbar" aria-hidden="false">
      <div class="bookbar__in">
        <span class="bookbar__name">{treatment.name}</span>
        <a class="btn bookbar__cta" href={`/contact?tx=${encodeURIComponent(treatment.name)}`}>Book a consult</a>
      </div>
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)}></script>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })}></script>
</Base>

<style>
  .detail__head { padding-top: var(--space-l); padding-bottom: var(--space-m); border-bottom: 1px solid var(--line); background: linear-gradient(to top, color-mix(in srgb, var(--accent) 13%, transparent), transparent 60%); }
  .detail__back { display: inline-block; margin-bottom: 1.4rem; }
  .detail__eyebrow { color: var(--accent-text); margin-bottom: 1.2rem; display: inline-flex; align-items: center; gap: 0.6em; }
  .detail__eyebrow::before { display: none; }
  .detail__dot { width: 9px; height: 9px; border-radius: 50%; background: var(--accent); }
  .detail__title { font-family: var(--display); font-weight: 400; letter-spacing: -0.015em; line-height: 1.04; font-size: var(--step-4); margin: 0; }
  .detail__essence { margin-top: 1.4rem; }

  .detail__grid { display: grid; grid-template-columns: 1fr 320px; gap: 3rem; padding-block: var(--space-l); }
  .detail__main { display: grid; gap: var(--space-l); }
  .detail__h { font-size: var(--step-2); margin-bottom: 1rem; }
  .detail__p { color: var(--graphite); }

  .supports { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.8rem; max-width: var(--measure); }
  .supports__item { display: grid; grid-template-columns: auto 1fr; gap: 0.8rem; align-items: baseline; color: var(--graphite); }
  .supports__tick { width: 7px; height: 7px; border-radius: 50%; background: var(--accent); transform: translateY(-1px); }

  .ix__heading { margin-bottom: 1.2rem; }
  .ix__list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0.6rem; }
  .ix { display: grid; grid-template-columns: auto 1fr; align-items: center; column-gap: 0.7rem; border: 1px solid var(--line); border-radius: var(--radius); padding: 0.7rem 0.9rem; text-decoration: none; transition: border-color 0.2s var(--ease), box-shadow 0.2s var(--ease); }
  .ix__dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); grid-row: span 2; align-self: center; box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 22%, transparent); }
  .ix__name { color: color-mix(in srgb, var(--accent) 70%, var(--ink)); font-size: var(--step-0); }
  .ix__line { grid-column: 2; font-family: var(--mono); font-size: 0.72rem; color: var(--mist); letter-spacing: 0.01em; }
  .ix:hover { border-color: var(--accent); }
  .ix__note { margin-top: 1.2rem; }

  .opts { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--line); max-width: var(--measure); }
  .opts__row { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; padding: 0.7rem 0; border-bottom: 1px solid var(--line); }
  .opts__label { display: flex; flex-direction: column; gap: 0.15rem; color: var(--ink); }
  .opts__note { color: var(--mist); font-size: var(--step--1); }

  .detail__side { align-self: start; position: sticky; top: calc(var(--header-h) + 1.5rem); display: grid; gap: 1rem; }
  .sidecard { border: 1px solid var(--line); border-radius: var(--radius); padding: 1.6rem 1.5rem; display: grid; gap: 0.8rem; background: var(--paper); }
  .sidecard--plain { background: var(--cloud); }
  .sidecard__line { font-family: var(--display); font-size: var(--step-1); line-height: 1.2; }
  .sidecard__cta { justify-content: center; margin-top: 0.4rem; }
  .sidecard__list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.6rem; }
  .sidecard__goals { border: 0; padding: 0; margin: 0; display: grid; gap: 0.6rem; }
  .sidecard__goals legend { padding: 0; }

  .help-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .help-chip { display: inline-flex; align-items: center; gap: 0.5em; font-size: var(--step--1); color: var(--graphite); border: 1px solid var(--line); border-radius: 999px; padding: 0.35em 0.85em; text-decoration: none; transition: border-color var(--dur-hover) var(--ease), color var(--dur-hover) var(--ease); }
  .help-chip__dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent); }
  .help-chip:hover { border-color: var(--accent); color: var(--ink); }

  .faqs { border-top: 1px solid var(--line); max-width: var(--measure); }
  .faq { border-bottom: 1px solid var(--line); }
  .faq summary { cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; padding: 1rem 0; font-family: var(--display); font-size: var(--step-1); }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::after { content: '+'; font-family: var(--mono); color: var(--mist); }
  .faq[open] summary::after { content: '\2013'; }
  .faq__a { color: var(--graphite); margin: 0; padding: 0 0 1.1rem; }

  .sec-head { max-width: 60ch; margin-bottom: var(--space-m); display: grid; gap: 1rem; }
  .detail__related-h { font-size: var(--step-3); }
  .related { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.2rem; }

  /* Breadcrumb */
  .crumbs { margin-bottom: 1.2rem; }
  .crumbs ol { list-style: none; display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; padding: 0; margin: 0; font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.04em; }
  .crumbs li { display: flex; align-items: center; gap: 0.5rem; }
  .crumbs li + li::before { content: '\203A'; color: var(--mist); }
  .crumbs a { color: var(--mist); text-decoration: none; transition: color var(--dur-hover) var(--ease); }
  .crumbs a:hover { color: var(--accent-text); }
  .crumbs [aria-current] { color: var(--ink); }

  /* Quick-fact tiles */
  .facts { margin: 2rem 0 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; max-width: 560px; }
  .facts__tile { background: var(--white-pure); background-image: var(--gloss-white); border: 1px solid var(--line); border-radius: var(--radius); padding: 0.9rem 1rem; }
  .facts__tile dt { font-family: var(--mono); font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--mist); }
  .facts__tile dd { margin: 0.3rem 0 0; color: var(--ink); font-size: var(--step-0); line-height: 1.25; }

  /* Who it's for */
  .cand { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; max-width: var(--measure); }
  .cand__label { font-family: var(--mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 0.9rem; }
  .cand__label--yes { color: var(--accent-text); }
  .cand__label--wait { color: var(--mist); }
  .cand__wait .supports__tick { background: var(--mist); }
  .cand__note { margin-top: 1.2rem; }

  /* Membership note in sidecard */
  .sidecard__member { margin: 0.2rem 0 0; }
  .sidecard__member a { color: var(--accent-text); text-decoration: underline; text-underline-offset: 2px; }

  /* Sticky mobile book bar */
  .bookbar { display: none; }
  .bookbar__in { display: flex; align-items: center; gap: 1rem; }
  .bookbar__name { font-family: var(--display); font-size: var(--step-0); line-height: 1.1; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .bookbar__cta { flex: none; }

  @media (max-width: 900px) {
    .detail__grid { grid-template-columns: 1fr; gap: 2rem; }
    .detail__side { position: static; }
  }
  @media (max-width: 640px) {
    .facts { grid-template-columns: 1fr; max-width: var(--measure); }
    .cand { grid-template-columns: 1fr; gap: 1.6rem; }
  }
  @media (max-width: 760px) {
    .bookbar {
      display: block; position: fixed; left: 0; right: 0; bottom: 0; z-index: 40;
      background: color-mix(in srgb, var(--white-pure) 92%, transparent);
      backdrop-filter: blur(10px); border-top: 1px solid var(--line);
      padding: 0.7rem 1.25rem calc(0.7rem + env(safe-area-inset-bottom));
    }
    .bookbar__cta { padding-block: 0.6rem; }
  }
</style>
