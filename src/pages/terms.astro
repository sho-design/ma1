---
import Base from '@layouts/Base.astro';
import PageHeader from '@components/PageHeader.astro';
import { site } from '@data/site';
---
<Base title="Terms" description="Terms of use for the Medical Aesthetics at Restoration Medical website.">
  <PageHeader eyebrow="Legal" title="Terms" lead="The basis on which this website is provided." />
  <section class="section-tight">
    <div class="wrap-narrow legal-prose reveal">
      <p class="meta">Template terms: replace with your reviewed version before publishing.</p>

      <h2>Information, not advice</h2>
      <p>The content on this site is general information about services offered by {site.brand}. It is <strong>not medical advice</strong> and does not create a physician–patient relationship. Nothing here guarantees a result; suitability and outcomes are determined in person and <strong>results vary</strong>.</p>

      <h2>No guarantees</h2>
      <p>In line with CPSO advertising standards, we describe what treatments <em>may</em> support and avoid promises of specific outcomes. Benefit language is intentionally measured.</p>

      <h2>Bookings &amp; forms</h2>
      <p>Consult requests are invitations to begin a conversation and screening, not a confirmed appointment or treatment plan. The demo forms on this site do not transmit data to a clinical system.</p>

      <h2>Intellectual property</h2>
      <p>The brand, copy, and design system are the property of {site.brand}. Please don’t reproduce them without permission.</p>

      <h2>Contact</h2>
      <p>Questions about these terms? Email <a href={`mailto:${site.email}`}>{site.email}</a>.</p>
    </div>
  </section>
</Base>

<style>
  .legal-prose h2 { font-size: var(--step-2); margin-top: var(--space-m); }
  .legal-prose p { color: var(--graphite); max-width: var(--measure); }
</style>
