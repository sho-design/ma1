---
import Base from '@layouts/Base.astro';
import PageHeader from '@components/PageHeader.astro';
import Advisory from '@components/Advisory.astro';
import GoalsChecklist from '@components/GoalsChecklist.astro';
import { treatments } from '@data/treatments';
import { familyBySlug } from '@data/families';
import { skinceuticals } from '@data/skinceuticals';

// Slug -> display info for the live "suggested treatments" list (client-side).
// `concerns` drives the SkinCeuticals product pairing.
const txMap = Object.fromEntries(
  treatments.map((t) => [t.slug, {
    name: t.name,
    accent: familyBySlug(t.family)?.accentVar ?? 'injectables',
    concerns: t.concerns,
  }])
);
---
<Base title="Plan your treatment" description="Mark your aesthetic goals and areas of concern, select all that apply, and we will shape a starting point for your consult. Not a prescription.">
  <PageHeader
    eyebrow="Plan your treatment"
    title="Mark what you would like to address."
    lead="Select all that apply, across face, body, hair and skin. We will suggest starting points, and your physician finalises everything at consult."
    ripple
  />

  <section class="section-tight">
    <div class="wrap planner">
      <div class="planner__form reveal">
        <GoalsChecklist />

        <fieldset class="goals__group" style="margin-top:var(--space-m)">
          <legend class="eyebrow">Comfort with downtime</legend>
          <div class="goals__items">
            {['None', 'A day or two', 'A few days is fine'].map((d) => (
              <label class="goal-chip">
                <input type="radio" name="downtime" value={d} />
                <span>{d}</span>
              </label>
            ))}
          </div>
        </fieldset>
      </div>

      <aside class="planner__summary reveal">
        <h2 style="font-size:var(--step-2)">Your starting point</h2>
        <p class="meta">Updates as you choose. Nothing is sent until you book.</p>

        <dl class="planner__out">
          <div><dt>Goals &amp; areas</dt><dd data-out="goal">Not set</dd></div>
          <div><dt>Downtime</dt><dd data-out="downtime">Not set</dd></div>
        </dl>

        <div class="saved-head" data-saved-head hidden>
          <p class="planner__label">Saved treatments</p>
          <div class="saved" data-saved></div>
        </div>

        <p class="planner__label">Suggested treatments</p>
        <div class="suggest" data-suggest>
          <p class="meta">Pick a goal to see related treatments.</p>
        </div>

        <div class="sc-head" data-sc-head hidden>
          <p class="planner__label">SkinCeuticals to pair at home</p>
          <p class="meta" style="margin:-0.2rem 0 0.6rem">Home care we often pair to support and extend your result.</p>
          <div class="sc" data-products></div>
          <p class="meta" style="margin-top:0.6rem"><a class="link-arrow" href="/treatments/skin-health-plan">Build a skin-health plan &rarr;</a></p>
        </div>

        <Advisory title="Not a prescription">
          These are starting points, not a treatment plan. We screen for
          candidacy and your physician finalises everything. Results vary.
        </Advisory>
        <a class="btn btn--lg" href="/contact" data-plan-cta style="margin-top:1.4rem">Take this to a consult</a>
      </aside>
    </div>
  </section>

  <script type="application/json" id="tx-map" set:html={JSON.stringify(txMap)}></script>
  <script type="application/json" id="sc-products" set:html={JSON.stringify(skinceuticals)}></script>
</Base>

<style>
  .planner { display: grid; grid-template-columns: 1.4fr 0.85fr; gap: var(--space-l); align-items: start; }
  .planner__summary { background: var(--white-pure); background-image: var(--gloss-white); border: 1px solid var(--line); border-radius: var(--radius); padding: var(--space-m); position: sticky; top: calc(var(--header-h) + 1rem); }
  .planner__label { font-family: var(--mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--mist); margin: 1.4rem 0 0.6rem; }
  .suggest { display: grid; gap: 0.35rem; }
  .suggest__row { display: flex; align-items: center; gap: 0.6rem; padding: 0.45rem 0.6rem; margin-inline: -0.6rem; border-radius: var(--radius); text-decoration: none; color: var(--ink); transition: background var(--dur-hover) var(--ease); }
  .suggest__row:hover { background: var(--cloud); }
  .suggest__dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); flex: none; }
  .suggest__name { font-size: var(--step--1); }
  .suggest__arrow { margin-left: auto; color: var(--mist); font-family: var(--mono); font-size: 0.8rem; }
  .saved { display: grid; gap: 0.35rem; }
  .saved__row { display: flex; align-items: center; gap: 0.6rem; padding: 0.45rem 0.6rem; margin-inline: -0.6rem; border-radius: var(--radius); }
  .saved__name { font-size: var(--step--1); color: var(--ink); text-decoration: none; }
  .saved__name:hover { color: var(--accent-text); }
  .saved__rm { margin-left: auto; border: 0; background: none; color: var(--mist); font-size: 1.1rem; line-height: 1; cursor: pointer; padding: 0.1rem 0.3rem; border-radius: 6px; }
  .saved__rm:hover { color: var(--ink); background: var(--cloud); }
  .sc { display: grid; gap: 0.5rem; }
  .sc__row { display: grid; grid-template-columns: 1fr auto; gap: 0.1rem 0.6rem; padding: 0.55rem 0.7rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--white-pure); }
  .sc__name { font-size: var(--step--1); color: var(--ink); font-weight: 500; }
  .sc__cat { font-family: var(--mono); font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent-skin-text, var(--mist)); align-self: center; }
  .sc__role { grid-column: 1 / -1; font-size: var(--step--1); color: var(--graphite); line-height: 1.4; }
  .planner__out { margin: 1.4rem 0; display: grid; gap: 0.9rem; border-top: 1px solid var(--line); padding-top: 1.4rem; }
  .planner__out dt { font-family: var(--mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--mist); }
  .planner__out dd { margin: 0.2rem 0 0; color: var(--ink); line-height: 1.5; }
  @media (max-width: 900px) { .planner { grid-template-columns: 1fr; } .planner__summary { position: static; } }
</style>

<script>
  import { getPlan, removeFromPlan } from '../scripts/plan';

  type Info = { name: string; accent: string; concerns: string[] };
  type Product = { slug: string; name: string; category: string; role: string; concerns: string[]; baseline?: boolean };
  const txMap: Record<string, Info> = JSON.parse(document.getElementById('tx-map')?.textContent || '{}');
  const products: Product[] = JSON.parse(document.getElementById('sc-products')?.textContent || '[]');
  const form = document.querySelector('.planner__form');
  const cta = document.querySelector<HTMLAnchorElement>('[data-plan-cta]');
  const suggestBox = document.querySelector<HTMLElement>('[data-suggest]');
  const savedBox = document.querySelector<HTMLElement>('[data-saved]');
  const savedHead = document.querySelector<HTMLElement>('[data-saved-head]');
  const productBox = document.querySelector<HTMLElement>('[data-products]');
  const productHead = document.querySelector<HTMLElement>('[data-sc-head]');

  const collect = (name: string) =>
    Array.from(document.querySelectorAll<HTMLInputElement>(`input[name="${name}"]:checked`));

  const renderSaved = () => {
    const saved = getPlan().filter((s) => txMap[s]);
    if (savedHead) savedHead.hidden = saved.length === 0;
    if (savedBox) {
      savedBox.innerHTML = saved
        .map((slug) => {
          const t = txMap[slug];
          return `<div class="saved__row" style="--accent: var(--accent-${t.accent})"><span class="suggest__dot"></span><a class="saved__name" href="/treatments/${slug}">${t.name}</a><button class="saved__rm" type="button" data-rm="${slug}" aria-label="Remove ${t.name}">&times;</button></div>`;
        })
        .join('');
    }
    return saved;
  };

  const update = () => {
    const goalEls = collect('goal');
    const goals = goalEls.map((i) => i.value);
    const downtime = collect('downtime').map((i) => i.value);

    const setOut = (key: string, val: string[]) => {
      const out = document.querySelector(`[data-out="${key}"]`);
      if (out) out.textContent = val.length ? val.join(', ') : 'Not set';
    };
    setOut('goal', goals);
    setOut('downtime', downtime);

    // Union of related treatments across selected goals, in first-seen order.
    const seen: string[] = [];
    for (const el of goalEls) {
      for (const slug of (el.dataset.treatments || '').split(',').filter(Boolean)) {
        if (!seen.includes(slug) && txMap[slug]) seen.push(slug);
      }
    }
    if (suggestBox) {
      suggestBox.innerHTML = seen.length
        ? seen
            .map((slug) => {
              const t = txMap[slug];
              return `<a class="suggest__row" href="/treatments/${slug}" style="--accent: var(--accent-${t.accent})"><span class="suggest__dot"></span><span class="suggest__name">${t.name}</span><span class="suggest__arrow">&rarr;</span></a>`;
            })
            .join('')
        : '<p class="meta">Pick a goal to see related treatments.</p>';
    }

    // Saved treatments are an explicit signal ("of interest"); goal-driven
    // suggestions are softer. We carry them to the consult separately.
    const saved = renderSaved();
    const allSlugs = [...new Set([...saved, ...seen])];

    // SkinCeuticals pairing: products matching the concerns of any chosen
    // treatment, plus the baseline (sunscreen) once anything is selected.
    const concernSet = new Set<string>();
    for (const slug of allSlugs) (txMap[slug]?.concerns || []).forEach((c) => concernSet.add(c));
    const matched = products.filter((p) => p.concerns.some((c) => concernSet.has(c)));
    const baseline = products.filter((p) => p.baseline && !matched.includes(p));
    const recommended = allSlugs.length ? [...matched, ...baseline] : [];
    if (productHead) productHead.hidden = recommended.length === 0;
    if (productBox) {
      productBox.innerHTML = recommended
        .map((p) => `<div class="sc__row"><span class="sc__name">${p.name}</span><span class="sc__cat">${p.category}</span><span class="sc__role">${p.role}</span></div>`)
        .join('');
    }

    const params = new URLSearchParams();
    if (goals.length) params.set('goals', goals.join('|'));
    if (downtime.length) params.set('downtime', downtime[0]);
    if (saved.length) params.set('interest', saved.map((s) => txMap[s].name).join('|'));
    if (seen.length) params.set('tx', seen.map((s) => txMap[s].name).join('|'));
    if (recommended.length) params.set('products', recommended.map((p) => p.name).join('|'));
    if (cta) cta.href = `/contact${params.toString() ? `?${params}` : ''}`;
  };

  savedBox?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-rm]');
    if (btn) removeFromPlan(btn.dataset.rm!);
  });
  document.addEventListener('plan:change', update);
  form?.addEventListener('change', update);
  update();
</script>
