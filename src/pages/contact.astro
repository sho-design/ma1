---
import Base from '@layouts/Base.astro';
import PageHeader from '@components/PageHeader.astro';
import ConsultForm from '@components/ConsultForm.astro';
import { site } from '@data/site';
---
<Base title="Book a consult" description="Request a consult. We screen first and tailor to you — your physician finalises any plan.">
  <PageHeader
    eyebrow="Book a consult"
    title="Let’s start with a conversation."
    lead="Tell us a little about your goals. We screen first, then tailor — and your physician finalises everything."
    ripple
  />

  <section class="section-tight">
    <div class="wrap contact">
      <div class="contact__form reveal">
        <ConsultForm />
      </div>
      <aside class="contact__aside reveal">
        <h2 style="font-size:var(--step-2)">Visit</h2>
        {site.locations.map((loc) => (
          <p class="contact__loc">
            <strong>{loc.name}</strong><br />
            {loc.address}<br />{loc.city}<br />
            <span class="meta">{loc.hours}</span>
          </p>
        ))}
        <h2 style="font-size:var(--step-2); margin-top:var(--space-m)">Reach us</h2>
        <p><a class="footer__link" style="display:inline" href={`mailto:${site.email}`}>{site.email}</a></p>
        <p><a class="footer__link" style="display:inline" href={`tel:${site.phone.replace(/[^0-9+]/g, '')}`}>{site.phone}</a></p>
        <p class="meta" style="margin-top:var(--space-m)">
          We respond during clinic hours. For anything urgent or medical, contact
          your physician or local emergency services — this form is not monitored
          for emergencies.
        </p>
      </aside>
    </div>
  </section>
</Base>

<style>
  .contact { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: var(--space-l); align-items: start; }
  .contact__loc { color: var(--graphite); margin-bottom: 1rem; }
  @media (max-width: 880px) { .contact { grid-template-columns: 1fr; } }
</style>

<script>
  // Carry planner selections (DESIGN_SYSTEM §6.3 configurator → consult).
  const params = new URLSearchParams(window.location.search);
  const goals = params.get('goals');
  const downtime = params.get('downtime');
  const families = params.get('families');
  if (goals || downtime || families) {
    const concern = document.querySelector<HTMLSelectElement>('#concern');
    const message = document.querySelector<HTMLTextAreaElement>('#message');
    const lines = [
      goals && `Goals: ${goals.split('|').join(', ')}`,
      families && `Interested in: ${families.split('|').join(', ')}`,
      downtime && `Comfortable downtime: ${downtime}`,
    ].filter(Boolean);
    if (message && lines.length) message.value = `From my plan —\n${lines.join('\n')}`;
    if (concern && goals) {
      const first = goals.split('|')[0].toLowerCase();
      const match = Array.from(concern.options).find((o) => o.textContent?.toLowerCase() === first);
      if (match) concern.value = match.value;
    }
  }
</script>
