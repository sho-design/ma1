---
import Base from '@layouts/Base.astro';
import HeroMotif from '@components/HeroMotif.astro';
import TreatmentCard from '@components/TreatmentCard.astro';
import ConcernTile from '@components/ConcernTile.astro';
import PullQuote from '@components/PullQuote.astro';
import CtaBand from '@components/CtaBand.astro';
import EvidenceTag from '@components/EvidenceTag.astro';
import { site } from '@data/site';
import { treatments } from '@data/treatments';
import { concerns } from '@data/concerns';

const featured = treatments.slice(0, 6);
const featuredConcerns = concerns.slice(0, 6);
---
<Base>
  <!-- Hero -->
  <section class="hero">
    <!-- Signature motif: a luminous light-bloom, set to the right behind the copy (§6.2) -->
    <div class="hero__motif" aria-hidden="true">
      <HeroMotif />
    </div>
    <div class="wrap hero__inner">
      <p class="eyebrow hero__eyebrow">{site.line} · {site.tagline.replace(/\.$/, '')}</p>
      <h1 class="hl hero__title ripple">Look like yourself, <span class="it">refined.</span></h1>
      <p class="lede hero__lead">
        Physician-led medical aesthetics. We screen first, tailor to you, and
        treat with restraint — subtle by design, honest about what each option
        can and cannot do.
      </p>
      <div class="hero__actions">
        <a class="btn btn--lg" href="/contact">Book a consult</a>
        <a class="link-arrow" href="/treatments">Explore treatments &rarr;</a>
      </div>
    </div>
    <div class="wrap hero__meta">
      <span class="meta">Physician-led</span>
      <span class="hero__sep" aria-hidden="true"></span>
      <span class="meta">Clinician-delivered</span>
      <span class="hero__sep" aria-hidden="true"></span>
      <span class="meta">Screened first</span>
    </div>
  </section>

  <!-- By Concern -->
  <section class="section-tight fill">
    <div class="wrap">
      <header class="section-head reveal">
        <span class="eyebrow">By Concern</span>
        <h2>Start with what you notice.</h2>
        <p class="lede">An empathetic entry point — we map your concern to the right modality, not the other way round.</p>
      </header>
      <div class="grid grid--concerns reveal" style="margin-top:2.5rem">
        {featuredConcerns.map((c) => <ConcernTile concern={c} />)}
      </div>
      <p style="margin-top:2rem"><a class="btn btn--ghost" href="/concerns">All concerns →</a></p>
    </div>
  </section>

  <PullQuote />

  <!-- Treatments -->
  <section class="section-tight">
    <div class="wrap">
      <header class="section-head reveal">
        <span class="eyebrow">Treatments</span>
        <h2>Five families, one clinical standard.</h2>
        <p class="lede">From injectables to medical-grade skin health — each held to the same physician oversight.</p>
      </header>
      <div class="grid grid--cards reveal" style="margin-top:2.5rem">
        {featured.map((t) => <TreatmentCard treatment={t} />)}
      </div>
      <p style="margin-top:2rem"><a class="btn btn--ghost" href="/treatments">All treatments →</a></p>
    </div>
  </section>

  <!-- Trust / medical anchor -->
  <section class="section-tight">
    <div class="wrap trust reveal">
      <div>
        <span class="eyebrow">The clinic, not the counter</span>
        <h2>Trust is a design feature.</h2>
        <p class="lede">
          Every option is reviewed by a physician and delivered by clinicians.
          We show our evidence rather than imply it — and we keep a genuine
          medical anchor in dermatology and scar revision.
        </p>
        <p style="margin-top:1.4rem; display:flex; gap:1.4rem; flex-wrap:wrap; align-items:center">
          <EvidenceTag level="established" />
          <EvidenceTag level="emerging" />
        </p>
        <p class="meta" style="margin-top:1rem">Hover the tags — every benefit claim is rated and honest.</p>
      </div>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .hero { position: relative; overflow: hidden; padding-block: clamp(3.5rem, 8vh, 7rem) var(--space-l); }
  .hero__inner, .hero__meta { position: relative; z-index: 2; }
  .hero__motif {
    position: absolute; z-index: 1;
    top: 50%; right: clamp(0.5rem, 5vw, 5rem);
    transform: translateY(-50%);
    width: clamp(220px, 26vw, 360px);
    aspect-ratio: 1 / 1;
    pointer-events: none;
  }
  .hero__eyebrow { margin-bottom: 2rem; }
  .hero__title { font-size: var(--step-5); max-width: 16ch; margin: 0; }
  .hero__lead { margin-top: 2rem; }
  .hero__actions { margin-top: 2.5rem; display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .hero__meta { margin-top: 3.5rem; display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; border-top: 1px solid var(--line); padding-top: 1.5rem; }
  .hero__sep { width: 4px; height: 4px; border-radius: 50%; background: var(--line); }
  @media (min-width: 1000px) {
    .hero__inner, .hero__meta { padding-right: clamp(280px, 28vw, 400px); }
  }
  @media (max-width: 999px) {
    .hero__motif { right: clamp(-60px, -4vw, -10px); opacity: 0.4; width: clamp(200px, 42vw, 280px); }
  }
  .section-head h2 { font-size: var(--step-3); }
  .section-head .lede { margin-top: 0.6rem; }
  .trust { max-width: var(--measure); }
</style>
