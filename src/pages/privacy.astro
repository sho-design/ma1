---
import Base from '@layouts/Base.astro';
import PageHeader from '@components/PageHeader.astro';
import { site } from '@data/site';
---
<Base title="Privacy" description="How Restoration Medical handles personal and health information under PHIPA.">
  <PageHeader eyebrow="Legal" title="Privacy" lead="How we handle your personal and personal health information." />
  <section class="section-tight">
    <div class="wrap-narrow legal-prose reveal">
      <p class="meta">Template notice — replace with your reviewed policy before publishing.</p>

      <h2>Our commitment</h2>
      <p>{site.brand} is a physician-led practice. We handle personal health information in accordance with Ontario’s <strong>Personal Health Information Protection Act (PHIPA)</strong> and applicable privacy law. Information you share is used to provide and coordinate your care and to operate the clinic.</p>

      <h2>What we collect</h2>
      <p>Contact details, the information you provide in consult requests, and — once you are a patient — the clinical information needed for safe, appropriate treatment. We collect only what we need.</p>

      <h2>How we use it</h2>
      <p>To screen for candidacy, plan and deliver care, communicate with you, meet regulatory obligations, and improve our service. We do not sell your information. This website’s demo forms are not connected to a clinical record and are illustrative only.</p>

      <h2>Your choices</h2>
      <p>You may ask to access or correct your information, and to understand how it is used. To make a request, contact us at <a href={`mailto:${site.email}`}>{site.email}</a>. You may also contact the Information and Privacy Commissioner of Ontario.</p>

      <h2>Retention &amp; security</h2>
      <p>Records are retained and safeguarded as required by PHIPA and CPSO standards, with access limited to those involved in your care or clinic operations.</p>
    </div>
  </section>
</Base>

<style>
  .legal-prose h2 { font-size: var(--step-2); margin-top: var(--space-m); }
  .legal-prose p { color: var(--graphite); max-width: var(--measure); }
</style>
