---
import Base from '@layouts/Base.astro';
import PageHeader from '@components/PageHeader.astro';
import ConcernTile from '@components/ConcernTile.astro';
import CtaBand from '@components/CtaBand.astro';
import { concerns } from '@data/concerns';
---
<Base title="By Concern" description="Start with what you notice: fine lines, volume, texture, pigmentation, redness, laxity, hair, and aging well.">
  <PageHeader
    eyebrow="By Concern"
    title="Start with what you notice."
    lead="An empathetic way in. Tell us the concern; we map it to the right modality, never the other way round. Each opens its own page with the treatments and modalities we would consider."
    ripple
  />

  <section class="section-tight">
    <div class="wrap">
      <div class="grid grid--concerns reveal">
        {concerns.map((c) => <ConcernTile concern={c} />)}
      </div>
    </div>
  </section>

  <CtaBand />
</Base>
