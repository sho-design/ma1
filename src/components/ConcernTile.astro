---
import type { Concern } from '@data/concerns';
import { familyBySlug } from '@data/families';
import ConcernIcon from './ConcernIcon.astro';
interface Props { concern: Concern; }
const { concern } = Astro.props;
const fam = familyBySlug(concern.families[0]);
const av = fam?.accentVar;
const style = av
  ? `--accent: var(--accent-${av}); --accent-text: var(--accent-${av}-text); --accent-vivid: var(--accent-${av}-vivid)`
  : '';
---
<a class="tile" id={concern.slug} href={`/concerns#${concern.slug}`} style={style}>
  <span class="tile__icon" aria-hidden="true">
    <ConcernIcon slug={concern.icon} size={28} class="tile__cicon" />
  </span>
  <span class="tile__label">{concern.label}</span>
  <span class="tile__line">{concern.line}</span>
  <span class="tile__more link-arrow">Explore &rarr;</span>
</a>
