---
import { concerns } from '@data/concerns';
import Advisory from './Advisory.astro';
---
<form class="consult-form" novalidate>
  <div class="interest-banner" data-interest-banner hidden>
    <p class="interest-banner__label">Treatments you're interested in</p>
    <div class="interest-banner__chips" data-interest-chips></div>
    <p class="interest-banner__note">We have noted these for your consult. Add anything else below.</p>
  </div>

  <div class="field">
    <label for="name">Name</label>
    <input id="name" name="name" type="text" autocomplete="name" required />
  </div>
  <div class="field">
    <label for="email">Email</label>
    <input id="email" name="email" type="email" autocomplete="email" required />
  </div>
  <div class="field">
    <label for="phone">Phone (optional)</label>
    <input id="phone" name="phone" type="tel" autocomplete="tel" />
  </div>
  <div class="field">
    <label for="concern">Primary concern</label>
    <select id="concern" name="concern">
      <option value="">Select…</option>
      {concerns.map((c) => <option value={c.slug}>{c.label}</option>)}
      <option value="other">Something else</option>
    </select>
  </div>
  <div class="field">
    <label for="message">What would you like to achieve?</label>
    <textarea id="message" name="message" placeholder="Tell us a little about your goals. We screen first, then tailor."></textarea>
  </div>

  <p class="meta" style="margin:0 0 1.4rem">
    Want to map specific goals across face, body, hair and skin?
    <a class="footer__link" style="display:inline" href="/plan">Plan your treatment &rarr;</a>
  </p>

  <Advisory title="Not a prescription">
    A consult is a conversation, not a guarantee. Your physician screens for
    candidacy and finalises any plan. Results vary.
  </Advisory>

  <button class="btn btn--lg" type="submit" style="margin-top:1.4rem">Request a consult</button>

  <div class="form__confirm" role="status" hidden data-confirm style="margin-top:1.4rem">
    Thank you. Your request is noted. A member of the clinic will be in touch to
    arrange screening. (This demo form has no endpoint; nothing was sent.)
  </div>
</form>

<style>
  .interest-banner { border: 1px solid var(--accent-injectables); border-left: 3px solid var(--accent-injectables); background: color-mix(in srgb, var(--accent-injectables) 8%, var(--white-pure)); border-radius: var(--radius); padding: 1rem 1.2rem; margin-bottom: 1.6rem; }
  .interest-banner__label { font-family: var(--mono); font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent-injectables-text); margin: 0 0 0.6rem; }
  .interest-banner__chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .interest-chip { display: inline-flex; align-items: center; gap: 0.4em; font-size: var(--step--1); background: var(--white-pure); border: 1px solid var(--line); border-radius: 999px; padding: 0.3em 0.8em; }
  .interest-chip::before { content: '\2605'; color: var(--accent-injectables-text); font-size: 0.7em; }
  .interest-banner__note { font-size: var(--step--1); color: var(--graphite); margin: 0.7rem 0 0; }
</style>

<script>
  // Graceful no-endpoint confirmation (DESIGN_SYSTEM §3 Forms).
  const form = document.querySelector<HTMLFormElement>('.consult-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }
    const confirm = form.querySelector<HTMLElement>('[data-confirm]');
    if (confirm) confirm.hidden = false;
    form.querySelectorAll('input, select, textarea, button[type=submit]').forEach((el) => {
      (el as HTMLInputElement).disabled = true;
    });
  });
</script>
