---
import type { Treatment } from '@data/treatments';
import { familyBySlug } from '@data/families';
interface Props { treatment: Treatment; }
const { treatment } = Astro.props;
const fam = familyBySlug(treatment.family);
const accent = fam
  ? `--accent: var(--accent-${fam.accentVar}); --accent-text: var(--accent-${fam.accentVar}-text)`
  : '';
---
<a class="card" href={`/treatments/${treatment.slug}`} style={accent} data-family={treatment.family} data-concerns={treatment.concerns.join(' ')}>
  <span class="card__top">
    <span class="card__family">{fam?.name}</span>
    {treatment.brand && <span class="card__type">{treatment.brand}</span>}
  </span>
  <span class="card__name">{treatment.name}</span>
  <span class="card__essence">{treatment.essence}</span>
  <span class="card__more link-arrow">Learn more &rarr;</span>
</a>
