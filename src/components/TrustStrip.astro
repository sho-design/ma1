---
// Trust anchor: the medical standards that make this a clinic, not a counter.
// Rendered as one calm editorial statement rather than a grid of cells.
// Key phrases carry a quiet emphasis; "Health Canada" keeps its en-dash.
---
<section class="truststrip">
  <div class="wrap">
    <p class="eyebrow truststrip__eyebrow reveal">Our standards</p>
    <p class="truststrip__statement reveal">
      Every treatment is <em>physician-supervised</em>, performed with
      <em>Health Canada–licensed devices</em>, and <em>screened for candidacy</em>
      first — with results that are real, consented and unretouched.
    </p>
  </div>
</section>

<style>
  .truststrip { border-bottom: 1px solid var(--line); background: var(--white-pure); background-image: var(--gloss-white); }
  .truststrip__eyebrow { text-align: center; margin-bottom: 1rem; }
  .truststrip__statement {
    max-width: 46ch; margin: 0 auto; padding-block: var(--space-s);
    text-align: center; text-wrap: balance;
    font-family: var(--display); font-weight: 400;
    font-size: var(--step-1); line-height: 1.42;
    color: color-mix(in srgb, var(--ink) 78%, var(--mist));
  }
  .truststrip__statement em {
    font-style: normal;
    color: var(--ink);
    box-shadow: inset 0 -0.42em 0 color-mix(in srgb, var(--accent-injectables-text) 12%, transparent);
  }
  @media (max-width: 640px) {
    .truststrip__statement { font-size: var(--step-0); max-width: 34ch; }
  }
</style>
