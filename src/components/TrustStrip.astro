---
// Trust-factor bar: the medical anchors that make this a clinic, not a counter.
// Rendered as one quiet inline credential line (icon + short label) rather than
// a grid of cells; the fuller claim sits in each item's tooltip. Icons are
// inline line-art (stroke = currentColor).
const items = [
  {
    label: 'Physician-supervised',
    note: 'Reviewed by a physician, delivered by clinicians.',
    path: '<path d="M5 3v5a5 5 0 0 0 10 0V3M10 13v3a5 5 0 0 0 5 5 4 4 0 0 0 4-4v-3" /><circle cx="19" cy="11" r="2" />',
  },
  {
    label: 'Health Canada–licensed devices',
    note: 'Approved platforms and products only.',
    path: '<path d="M12 3l7 3v5c0 5-3.5 8.5-7 10-3.5-1.5-7-5-7-10V6l7-3z" /><path d="M9 12l2 2 4-4" />',
  },
  {
    label: 'Screened first, always',
    note: 'Candidacy and safety before anything else.',
    path: '<circle cx="11" cy="11" r="6" /><path d="M20 20l-4.3-4.3" />',
  },
  {
    label: 'Consented, unretouched results',
    note: 'Real photos, with written consent. Results vary.',
    path: '<rect x="3" y="6" width="18" height="14" rx="2" /><circle cx="12" cy="13" r="3.5" /><path d="M8 6l1.5-2h5L16 6" />',
  },
];
---
<section class="truststrip">
  <div class="wrap">
    <ul class="trust-row reveal" aria-label="What makes this a clinic">
      {items.map((it) => (
        <li class="trustf" title={it.note}>
          <svg class="trustf__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={it.path}></svg>
          <span class="trustf__label">{it.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .truststrip { border-bottom: 1px solid var(--line); background: var(--white-pure); background-image: var(--gloss-white); }
  .trust-row {
    list-style: none; margin: 0; padding: 1rem 0;
    display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
    gap: 0.85rem 1.6rem;
  }
  .trustf {
    display: inline-flex; align-items: center; gap: 0.55rem;
    position: relative;
  }
  /* Hairline separators between items instead of boxed cells */
  .trustf + .trustf::before {
    content: ''; position: absolute; left: -0.8rem; top: 50%; transform: translateY(-50%);
    width: 1px; height: 1.05em; background: var(--line);
  }
  .trustf__icon { width: 19px; height: 19px; flex: none; color: var(--accent-injectables-text); }
  .trustf__label { font-size: var(--step--1); line-height: 1.2; color: var(--ink); letter-spacing: 0.005em; }
  @media (max-width: 640px) {
    .trust-row { gap: 0.7rem 1.2rem; }
    .trustf + .trustf::before { left: -0.6rem; }
  }
</style>
