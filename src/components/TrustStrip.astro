---
// Trust-factor strip: the medical anchors that make this a clinic, not a
// counter. Icons are inline line-art (stroke = currentColor). "Health Canada"
// uses an en-dash in "Canada-licensed" by design.
const items = [
  {
    label: 'Physician-supervised care',
    note: 'Reviewed by a physician, delivered by clinicians.',
    path: '<path d="M5 3v5a5 5 0 0 0 10 0V3M10 13v3a5 5 0 0 0 5 5 4 4 0 0 0 4-4v-3" /><circle cx="19" cy="11" r="2" />',
  },
  {
    label: 'Health Canada–licensed devices',
    note: 'Approved platforms and products only.',
    path: '<path d="M12 3l7 3v5c0 5-3.5 8.5-7 10-3.5-1.5-7-5-7-10V6l7-3z" /><path d="M9 12l2 2 4-4" />',
  },
  {
    label: 'Screened first, always',
    note: 'Candidacy and safety before anything else.',
    path: '<circle cx="11" cy="11" r="6" /><path d="M20 20l-4.3-4.3" />',
  },
  {
    label: 'Consented, unretouched results',
    note: 'Real photos, with written consent. Results vary.',
    path: '<rect x="3" y="6" width="18" height="14" rx="2" /><circle cx="12" cy="13" r="3.5" /><path d="M8 6l1.5-2h5L16 6" />',
  },
];
---
<section class="truststrip">
  <div class="wrap">
    <ul class="trust-row reveal">
      {items.map((it) => (
        <li class="trustf">
          <svg class="trustf__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={it.path}></svg>
          <span class="trustf__text">
            <span class="trustf__label">{it.label}</span>
            <span class="trustf__note">{it.note}</span>
          </span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .truststrip { border-block: 1px solid var(--line); background: var(--white-pure); background-image: var(--gloss-white); }
  .trust-row {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(4, 1fr);
  }
  .trustf {
    display: flex; align-items: center; gap: 0.8rem;
    padding: 1.3rem 1.4rem;
  }
  .trustf + .trustf { border-left: 1px solid var(--line); }
  .trustf__icon { width: 26px; height: 26px; flex: none; color: var(--accent-injectables-text); }
  .trustf__text { display: grid; gap: 0.15rem; }
  .trustf__label { font-size: var(--step-0); line-height: 1.2; color: var(--ink); }
  .trustf__note { font-size: var(--step--1); color: var(--mist); line-height: 1.3; }
  @media (max-width: 900px) {
    .trust-row { grid-template-columns: repeat(2, 1fr); }
    .trustf:nth-child(3) { border-left: 0; }
    .trustf:nth-child(n+3) { border-top: 1px solid var(--line); }
  }
  @media (max-width: 520px) {
    .trust-row { grid-template-columns: 1fr; }
    .trustf + .trustf { border-left: 0; border-top: 1px solid var(--line); }
  }
</style>
