---
import { site } from '@data/site';
import { families } from '@data/families';
const year = new Date().getFullYear();
const tel = site.phone.replace(/[^0-9+]/g, '');

const socials = [
  { name: 'Instagram', d: 'M12 2c2.717 0 3.056.01 4.122.06 1.065.05 1.79.217 2.428.465.66.254 1.216.598 1.772 1.153a4.908 4.908 0 0 1 1.153 1.772c.247.637.415 1.363.465 2.428.047 1.066.06 1.405.06 4.122 0 2.717-.01 3.056-.06 4.122-.05 1.065-.218 1.79-.465 2.428a4.883 4.883 0 0 1-1.153 1.772 4.915 4.915 0 0 1-1.772 1.153c-.637.247-1.363.415-2.428.465-1.066.047-1.405.06-4.122.06-2.717 0-3.056-.01-4.122-.06-1.065-.05-1.79-.218-2.428-.465a4.89 4.89 0 0 1-1.772-1.153 4.904 4.904 0 0 1-1.153-1.772c-.248-.637-.415-1.363-.465-2.428C2.013 15.056 2 14.717 2 12c0-2.717.01-3.056.06-4.122.05-1.066.217-1.79.465-2.428a4.88 4.88 0 0 1 1.153-1.772A4.897 4.897 0 0 1 5.45 2.525c.638-.248 1.362-.415 2.428-.465C8.944 2.013 9.283 2 12 2zm0 1.8c-2.67 0-2.987.01-4.04.059-.976.045-1.505.207-1.858.344-.466.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.352-.3.882-.344 1.857-.048 1.054-.058 1.37-.058 4.041 0 2.67.01 2.988.058 4.04.045.977.207 1.506.344 1.858.182.466.399.8.748 1.15.35.35.684.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058 2.67 0 2.988-.01 4.04-.058.977-.045 1.506-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.352.3-.881.344-1.857.048-1.053.058-1.37.058-4.04 0-2.671-.01-2.988-.058-4.041-.045-.976-.207-1.505-.344-1.857a3.097 3.097 0 0 0-.748-1.15 3.098 3.098 0 0 0-1.15-.748c-.352-.137-.882-.3-1.857-.344-1.053-.048-1.37-.059-4.04-.059zm0 3.064A5.136 5.136 0 1 1 12 17.2a5.136 5.136 0 0 1 0-10.272zm0 1.8a3.336 3.336 0 1 0 0 6.672 3.336 3.336 0 0 0 0-6.672zm6.538-2.94a1.2 1.2 0 1 1-2.4 0 1.2 1.2 0 0 1 2.4 0z' },
  { name: 'Facebook', d: 'M22 12.06C22 6.504 17.523 2 12 2S2 6.504 2 12.06c0 5.022 3.657 9.184 8.438 9.94v-7.03H7.898v-2.91h2.54V9.845c0-2.522 1.492-3.915 3.777-3.915 1.094 0 2.238.196 2.238.196v2.476h-1.26c-1.243 0-1.63.775-1.63 1.57v1.888h2.773l-.443 2.91h-2.33v7.03C18.343 21.244 22 17.082 22 12.06z' },
  { name: 'TikTok', d: 'M16.5 2h-3v13.5a2.5 2.5 0 1 1-2.5-2.5c.17 0 .34.02.5.05V9.96A6 6 0 0 0 5 16a6 6 0 0 0 12 0V8.6a7.45 7.45 0 0 0 4 1.17V6.7a4.5 4.5 0 0 1-4.5-4.7z' },
];

const treatmentLinks = families.filter((f) => f.slug !== 'clinical' && f.slug !== 'health');
---
<footer class="footer">
  <div class="wrap footer__top">
    <div class="footer__brand">
      <p class="footer__name hl">{site.line}</p>
      <p class="eyebrow">at {site.brand} · {site.tagline}</p>
      <p class="footer__pitch measure">
        Natural-looking results, held to a clinical standard. Screened first,
        tailored to you, and finalised by your physician.
      </p>
      <div class="footer__socials">
        <ul class="socials" aria-label="Social media">
          {socials.map((s) => (
            <li>
              <span class="social social--pending" aria-label={`${s.name} (coming soon)`} role="img">
                <svg class="social__svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={s.d} /></svg>
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <nav class="footer__nav" aria-label="Footer">
      <div class="footer__col">
        <p class="footer__heading">Treatments</p>
        <ul>
          {treatmentLinks.map((f) => <li><a href={`/treatments#${f.slug}`}>{f.name}</a></li>)}
          <li><a href="/treatments">All treatments</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <p class="footer__heading">Explore</p>
        <ul>
          <li><a href="/concerns">By Concern</a></li>
          <li><a href="/modalities">Modalities &amp; actives</a></li>
          <li><a href="/plan">Plan your treatment</a></li>
          <li><a href="/candidacy">Candidacy &amp; safety</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <p class="footer__heading">Clinic</p>
        <ul>
          <li><a href="/treatments#health">Skin Health</a></li>
          <li><a href="/treatments#clinical">Clinical / Consult</a></li>
          <li><a href="/memberships">Memberships</a></li>
          <li><a href="/contact">Book a consult</a></li>
        </ul>
      </div>
    </nav>
  </div>

  <div class="wrap footer__locations">
    {site.locations.map((loc) => (
      <div class="footer__loc">
        <p class="footer__loc-title">{loc.city}</p>
        <p class="footer__meta">{loc.name}</p>
        <p class="footer__meta">{loc.address}</p>
        <p class="footer__meta">{loc.hours}</p>
      </div>
    ))}
    <div class="footer__loc">
      <p class="footer__loc-title">Reach us</p>
      <p class="footer__meta"><a href={`mailto:${site.email}`}>{site.email}</a></p>
      <p class="footer__meta"><a href={`tel:${tel}`}>{site.phone}</a></p>
    </div>
  </div>

  <div class="wrap footer__legal">
    <p class="footer__fine">
      Medical aesthetic services are elective and are not covered by OHIP. Every
      treatment is physician-led and clinician-delivered. Information on this site
      is educational and is not medical advice. Results vary from person to
      person, and a consult confirms what is right for you.
    </p>
    <p class="footer__fine">© {year} {site.brand}. With care, the {site.brand} team.</p>
    <p class="footer__legallinks">
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms of Use</a>
      <a href="/accessibility">Accessibility</a>
    </p>
  </div>
</footer>
