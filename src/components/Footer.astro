---
import { site } from '@data/site';
import { families } from '@data/families';
import Socials from './Socials.astro';
const year = new Date().getFullYear();

const treatmentLinks = families.filter((f) => f.slug !== 'clinical' && f.slug !== 'health');

// Keyless Google Maps embed + view/directions deep-links, driven by mapQuery.
const mapEmbed = (q: string) => `https://maps.google.com/maps?q=${encodeURIComponent(q)}&z=15&output=embed`;
const placeLink = (q: string) => `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(q)}`;
const directions = (q: string) => `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(q)}`;
---
<footer class="footer">
  <div class="wrap footer__top">
    <div class="footer__brand">
      <p class="footer__name hl">{site.line}</p>
      <p class="eyebrow">at {site.brand} · {site.tagline}</p>
      <p class="footer__pitch measure">
        Natural-looking results, held to a clinical standard. Screened first,
        tailored to you, and finalised by your physician.
      </p>
      <div class="footer__socials">
        <Socials />
      </div>
    </div>

    <nav class="footer__nav" aria-label="Footer">
      <div class="footer__col">
        <p class="footer__heading">Treatments</p>
        <ul>
          {treatmentLinks.map((f) => <li><a href={`/treatments#${f.slug}`}>{f.name}</a></li>)}
          <li><a href="/treatments">All treatments</a></li>
          <li><a href="/menu">Treatment menu</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <p class="footer__heading">Explore</p>
        <ul>
          <li><a href="/concerns">By Concern</a></li>
          <li><a href="/protocols">Protocols</a></li>
          <li><a href="/modalities">Modalities &amp; actives</a></li>
          <li><a href="/plan">Plan your treatment</a></li>
          <li><a href="/faqs">FAQs</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <p class="footer__heading">Clinic</p>
        <ul>
          <li><a href="/team">Care team</a></li>
          <li><a href="/locations">Locations</a></li>
          <li><a href="/candidacy">Candidacy &amp; safety</a></li>
          <li><a href="/memberships">Memberships</a></li>
          <li><a href="/contact">Book a consult</a></li>
        </ul>
      </div>
    </nav>
  </div>

  <div class="wrap footer__bottom">
    <div class="footer__locations">
      {site.locations.map((loc) => (
        <div class="footer__loc">
          <p class="footer__loc-title">{loc.label}</p>
          <p class="footer__meta">{loc.address}, {loc.city} {loc.postal}</p>
          <div class="footer__map">
            <a class="footer__map-frame" href={placeLink(loc.mapQuery)} target="_blank" rel="noopener noreferrer" aria-label={`View ${loc.label} on Google`}>
              <iframe
                src={mapEmbed(loc.mapQuery)}
                title={`Map of ${loc.label}`}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                tabindex="-1"
                aria-hidden="true"
              ></iframe>
            </a>
            <a class="footer__map-cta" href={directions(loc.mapQuery)} target="_blank" rel="noopener noreferrer" aria-label={`Get directions to ${loc.label} on Google Maps`}>
              Get directions
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6"></path>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="footer__legal">
      <nav class="footer__network" aria-label="Our network">
        <p class="footer__network-h">Our network</p>
        <ul>
          {site.network.map((n) => (
            <li>
              <a href={n.href} target="_blank" rel="noopener noreferrer">
                <span class="footer__network-label">
                  {n.name}
                  <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 17 17 7M9 7h8v8"></path>
                  </svg>
                </span>
                <span class="footer__network-note">{n.note}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="footer__legal-main">
        <p class="footer__fine">
          Medical aesthetic services are elective and are not covered by OHIP. Every
          treatment is physician-led and clinician-delivered. Information on this site
          is educational and is not medical advice. Results vary from person to
          person, and a consult confirms what is right for you.
        </p>
        <p class="footer__fine">© {year} {site.brand}. With care, the {site.brand} team.</p>
        <p class="footer__legallinks">
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms of Use</a>
          <a href="/accessibility">Accessibility</a>
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Location map cards — mirrors the sibling infusion-therapy footer */
  .footer__locations { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; padding-block: var(--space-l); border-bottom: 1px solid rgba(252, 252, 253, 0.14); }
  .footer__meta { color: #fcfcfdb8; font-size: var(--step--1); }
  .footer__map { margin-top: 0.9rem; border-radius: var(--radius); overflow: hidden; border: 1px solid rgba(252, 252, 253, 0.14); background: #fcfcfd0a; transition: border-color var(--dur-hover) var(--ease); }
  .footer__map:hover { border-color: #fcfcfd52; }
  .footer__map-frame { display: block; position: relative; height: 130px; }
  .footer__map-frame:focus-visible { outline: 2px solid var(--paper); outline-offset: -2px; }
  .footer__map-frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; pointer-events: none; filter: grayscale(0.35) contrast(0.95) brightness(0.96); transition: filter var(--dur-hover) var(--ease); }
  .footer__map-frame:hover iframe { filter: grayscale(0.1) contrast(1) brightness(1); }
  .footer__map-cta { display: flex; align-items: center; gap: 0.4rem; padding: 0.5rem 0.7rem; font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.1em; text-transform: uppercase; color: #fcfcfdcc; border-top: 1px solid rgba(252, 252, 253, 0.12); transition: color var(--dur-hover) var(--ease); }
  .footer__map-cta:hover { color: var(--paper); }
  .footer__map-cta:focus-visible { outline: 2px solid var(--paper); outline-offset: -2px; }
  .footer__map-cta svg { transition: transform var(--dur-hover) var(--ease); }
  .footer__map-cta:hover svg { transform: translateX(3px); }

  /* Our network + legal */
  .footer__legal { padding-top: var(--space-m); display: grid; grid-template-columns: auto 1fr; gap: 2rem 3rem; align-items: start; }
  .footer__legal-main { display: grid; gap: 0.8rem; }
  .footer__network { justify-self: start; min-width: 12rem; }
  .footer__network-h { font-family: var(--mono); font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase; color: #fcfcfd8c; margin-bottom: 1rem; }
  .footer__network ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.9rem; }
  .footer__network a { display: grid; gap: 0.15rem; color: inherit; }
  .footer__network-label { display: inline-flex; align-items: center; gap: 0.35rem; font-family: var(--display); font-size: var(--step-0); color: var(--paper); }
  .footer__network-label svg { color: #fcfcfd80; transition: transform 0.25s var(--ease), color 0.25s var(--ease); }
  .footer__network a:hover .footer__network-label svg { transform: translate(2px, -2px); color: var(--paper); }
  .footer__network-note { font-size: 0.72rem; color: #fcfcfd80; }

  @media (max-width: 820px) {
    .footer__locations { grid-template-columns: 1fr 1fr; }
    .footer__legal { grid-template-columns: 1fr; gap: 1.8rem; }
    .footer__network { justify-self: start; }
  }
  @media (max-width: 520px) {
    .footer__locations { grid-template-columns: 1fr; }
  }
</style>
