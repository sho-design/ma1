---
// Decorative line-art: front face, profile, front body, back body.
// Single-stroke, currentColor, rounded caps (matches the ConcernIcon language).
// Purely illustrative context for the goals checklist (aria-hidden).
---
<div class="bodymap" aria-hidden="true">
  <svg viewBox="0 0 64 96" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
    <!-- front face -->
    <path d="M32 8c11 0 18 8 18 21 0 8-2 14-6 20-3 5-7 9-12 9s-9-4-12-9c-4-6-6-12-6-20C14 16 21 8 32 8Z" />
    <path d="M14 30c-3 0-5 2-5 5s2 5 5 5" />
    <path d="M50 30c3 0 5 2 5 5s-2 5-5 5" />
    <path d="M22 31c2-1.6 5-1.6 7 0" />
    <path d="M35 31c2-1.6 5-1.6 7 0" />
    <circle cx="25.5" cy="38" r="1.3" fill="currentColor" stroke="none" />
    <circle cx="38.5" cy="38" r="1.3" fill="currentColor" stroke="none" />
    <path d="M32 39v8l-3 2" />
    <path d="M27 57c3 2 7 2 10 0" />
  </svg>

  <svg viewBox="0 0 64 96" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
    <!-- profile -->
    <path d="M44 9c-10-2-22 5-24 19-.5 4-.5 7-3 10-2 2-5 5-5 7s3 3 5 3c1 4 1 8 5 11 4 4 10 5 15 4" />
    <path d="M17 45c1.5 0 3 .6 4 1.6" />
    <path d="M30 33c-1.5 1-3 1-4.5 0" />
    <circle cx="27" cy="29" r="1.2" fill="currentColor" stroke="none" />
  </svg>

  <svg viewBox="0 0 60 120" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
    <!-- front body -->
    <circle cx="30" cy="13" r="9" />
    <path d="M30 22c-7 0-12 4-13.5 11l-3.5 21c-.5 3 1.5 4 3.5 2.7l2-1.4 1 33c.1 3.2 4.3 3.2 4.4 0L29 78h2l2.1 20.3c.1 3.2 4.3 3.2 4.4 0l1-33 2 1.4c2 1.3 4 .3 3.5-2.7l-3.5-21C39 26 34 22 27 22Z" />
    <path d="M22 44c2.4 1.6 5.4 2.4 8 2.4s5.6-.8 8-2.4" />
  </svg>

  <svg viewBox="0 0 60 120" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
    <!-- back body -->
    <circle cx="30" cy="13" r="9" />
    <path d="M30 22c-7 0-12 4-13.5 11l-3.5 21c-.5 3 1.5 4 3.5 2.7l2-1.4 1 33c.1 3.2 4.3 3.2 4.4 0L29 78h2l2.1 20.3c.1 3.2 4.3 3.2 4.4 0l1-33 2 1.4c2 1.3 4 .3 3.5-2.7l-3.5-21C39 26 34 22 27 22Z" />
    <path d="M30 25v52" />
  </svg>
</div>

<style>
  .bodymap { display: flex; gap: clamp(0.5rem, 3vw, 2rem); align-items: flex-end; justify-content: center; color: color-mix(in srgb, var(--accent, var(--mist)) 55%, var(--mist)); padding: var(--space-s) 0 var(--space-m); }
  .bodymap svg { height: clamp(110px, 18vw, 160px); width: auto; }
  .bodymap svg:nth-child(1), .bodymap svg:nth-child(2) { height: clamp(86px, 14vw, 124px); }
  @media (max-width: 520px) { .bodymap svg:nth-child(2) { display: none; } }
</style>
