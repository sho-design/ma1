---
import { partners } from '@data/partners';
---
<section class="section-tight fill partners-sec">
  <div class="wrap">
    <p class="eyebrow partners__eyebrow reveal">The tools we trust</p>
    <ul class="partners reveal">
      {partners.map((p) => (
        <li class="partner-cell">
          <a class="partner" href={p.href} title={`${p.name}: ${p.note}`} style={`--accent: var(--accent-${p.accent}); --accent-text: var(--accent-${p.accent}-text)`}>
            <span class="partner__name">{p.name}</span>
            <span class="partner__note">{p.note}</span>
            <span class="partner__go" aria-hidden="true">View &rarr;</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .partners-sec { padding-block: var(--space-m); }
  .partners__eyebrow { text-align: center; margin-bottom: 1.6rem; }
  .partners {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1px; background: var(--line);
    border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden;
  }
  .partner-cell { display: flex; }
  .partner {
    position: relative; width: 100%;
    display: grid; gap: 0.25rem; place-content: center; justify-items: center; text-align: center;
    background: var(--white-pure); padding: 1.5rem 1rem; min-height: 104px;
    text-decoration: none; color: inherit;
    transition: background var(--dur-hover) var(--ease), box-shadow var(--dur-hover) var(--ease);
  }
  .partner::before {
    content: ''; position: absolute; inset: 0 0 auto 0; height: 3px;
    background: var(--accent); transform: scaleX(0); transform-origin: left;
    transition: transform var(--dur-hover) var(--ease);
  }
  .partner__name {
    font-family: var(--display); font-size: var(--step-1); line-height: 1.1;
    color: color-mix(in srgb, var(--ink) 78%, var(--mist));
    transition: color var(--dur-hover) var(--ease);
  }
  .partner__note { font-family: var(--mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--mist); }
  .partner__go {
    font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.08em; color: var(--accent-text);
    opacity: 0; transform: translateY(4px);
    transition: opacity var(--dur-hover) var(--ease), transform var(--dur-hover) var(--ease);
    margin-top: 0.2rem;
  }
  .partner:hover, .partner:focus-visible {
    background: color-mix(in srgb, var(--accent) 6%, var(--white-pure));
    box-shadow: 0 14px 30px -22px color-mix(in srgb, var(--accent) 70%, transparent);
    outline: none;
  }
  .partner:hover::before, .partner:focus-visible::before { transform: scaleX(1); }
  .partner:hover .partner__name, .partner:focus-visible .partner__name { color: var(--accent-text); }
  .partner:hover .partner__go, .partner:focus-visible .partner__go { opacity: 1; transform: translateY(0); }

  @media (max-width: 760px) { .partners { grid-template-columns: repeat(2, 1fr); } }
  @media (prefers-reduced-motion: reduce) {
    .partner, .partner::before, .partner__name, .partner__go { transition: none; }
  }
</style>
