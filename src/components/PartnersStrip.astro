---
import { partners } from '@data/partners';
// Duplicated once so the track can loop seamlessly (translateX -50%).
const loop = [...partners, ...partners];
---
<section class="section-tight fill partners-sec">
  <div class="wrap">
    <p class="eyebrow partners__eyebrow reveal">The tools we trust</p>
  </div>

  <div class="marquee reveal" data-marquee aria-label="Brands and platforms we treat with">
    <div class="marquee__track">
      {loop.map((p, i) => (
        <a
          class="partner"
          href={p.href}
          title={`${p.name}: ${p.note}`}
          aria-hidden={i >= partners.length ? 'true' : undefined}
          tabindex={i >= partners.length ? -1 : undefined}
          style={`--accent: var(--accent-${p.accent}); --accent-text: var(--accent-${p.accent}-text)`}
        >
          <span class="partner__name">{p.name}</span>
          <span class="partner__note">{p.note}</span>
          <span class="partner__go" aria-hidden="true">View &rarr;</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .partners-sec { position: relative; padding-block: var(--space-m); overflow: hidden; }
  .partners__eyebrow { text-align: center; margin-bottom: 1.6rem; }

  /* Edge fades as overlays (no mask/compositing layer, which can leak a hairline) */
  .partners-sec::before, .partners-sec::after {
    content: ''; position: absolute; top: 0; bottom: 0; width: 7%; z-index: 2; pointer-events: none;
  }
  .partners-sec::before { left: 0; background: linear-gradient(90deg, var(--cloud), transparent); }
  .partners-sec::after { right: 0; background: linear-gradient(270deg, var(--cloud), transparent); }

  .marquee { position: relative; }
  .marquee__track {
    display: flex; width: max-content; gap: 1rem;
    animation: partners-scroll 46s linear infinite;
    will-change: transform;
  }
  .marquee:hover .marquee__track,
  .marquee:focus-within .marquee__track { animation-play-state: paused; }
  @keyframes partners-scroll { to { transform: translateX(calc(-50% - 0.5rem)); } }

  .partner {
    position: relative; flex: none; width: 230px;
    display: grid; gap: 0.25rem; place-content: center; justify-items: center; text-align: center;
    background: var(--white-pure); background-image: var(--gloss-white);
    border: 1px solid var(--line); border-radius: var(--radius);
    padding: 1.5rem 1.2rem; min-height: 104px;
    text-decoration: none; color: inherit;
    transition: background var(--dur-hover) var(--ease), box-shadow var(--dur-hover) var(--ease), transform var(--dur-hover) var(--ease), border-color var(--dur-hover) var(--ease);
  }
  .partner::before {
    content: ''; position: absolute; inset: 0 0 auto 0; height: 3px; border-radius: var(--radius) var(--radius) 0 0;
    background: var(--accent); opacity: 0;
    transition: opacity var(--dur-hover) var(--ease);
  }
  .partner__name {
    font-family: var(--display); font-size: var(--step-1); line-height: 1.1;
    color: color-mix(in srgb, var(--ink) 80%, var(--mist));
    transition: color var(--dur-hover) var(--ease);
  }
  .partner__note { font-family: var(--mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--mist); }
  .partner__go {
    font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.08em; color: var(--accent-text);
    opacity: 0; transform: translateY(4px); margin-top: 0.2rem;
    transition: opacity var(--dur-hover) var(--ease), transform var(--dur-hover) var(--ease);
  }
  .partner:hover, .partner:focus-visible {
    background: color-mix(in srgb, var(--accent) 7%, var(--white-pure));
    border-color: color-mix(in srgb, var(--accent) 45%, var(--line));
    box-shadow: 0 16px 32px -22px color-mix(in srgb, var(--accent) 70%, transparent);
    transform: translateY(-3px); outline: none;
  }
  .partner:hover::before, .partner:focus-visible::before { opacity: 0.9; }
  .partner:hover .partner__name, .partner:focus-visible .partner__name { color: var(--accent-text); }
  .partner:hover .partner__go, .partner:focus-visible .partner__go { opacity: 1; transform: translateY(0); }

  @media (prefers-reduced-motion: reduce) {
    .marquee { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .marquee__track { animation: none; padding-inline: 1.25rem; }
    .partner, .partner::before, .partner__name, .partner__go { transition: none; }
  }
</style>
