---
import { partners } from '@data/partners';
// Duplicated once so the track can loop seamlessly (translateX -50%).
const loop = [...partners, ...partners];
---
<section class="section-tight fill partners-sec">
  <div class="wrap">
    <p class="eyebrow partners__eyebrow reveal">The tools we trust</p>
  </div>

  <div class="marquee reveal" data-marquee aria-label="Brands and platforms we treat with">
    <div class="marquee__track">
      {loop.map((p, i) => (
        <a
          class="partner"
          href={p.href}
          title={`${p.name}: ${p.note}`}
          aria-hidden={i >= partners.length ? 'true' : undefined}
          tabindex={i >= partners.length ? -1 : undefined}
          style={`--accent-text: var(--accent-${p.accent}-text)`}
        >
          <span class="partner__name">{p.name}</span>
          <span class="partner__note">{p.note}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .partners-sec { position: relative; padding-block: var(--space-m); overflow: hidden; }
  .partners__eyebrow { text-align: center; margin-bottom: 1.4rem; }

  /* Edge fades as overlays (no mask layer, which can leak a hairline) */
  .partners-sec::before, .partners-sec::after {
    content: ''; position: absolute; top: 0; bottom: 0; width: 9%; z-index: 2; pointer-events: none;
  }
  .partners-sec::before { left: 0; background: linear-gradient(90deg, var(--cloud), transparent); }
  .partners-sec::after { right: 0; background: linear-gradient(270deg, var(--cloud), transparent); }

  .marquee { position: relative; }
  .marquee__track {
    display: flex; width: max-content;
    animation: partners-scroll 48s linear infinite;
    will-change: transform;
  }
  .marquee:hover .marquee__track,
  .marquee:focus-within .marquee__track { animation-play-state: paused; }
  @keyframes partners-scroll { to { transform: translateX(-50%); } }

  .partner {
    flex: none;
    display: grid; gap: 0.3rem; place-content: center; justify-items: center; text-align: center;
    padding: 0.4rem 2.6rem; border-left: 1px solid var(--line);
    text-decoration: none; color: inherit;
  }
  .partner__name {
    font-family: var(--display); font-size: var(--step-2); line-height: 1.05;
    color: color-mix(in srgb, var(--ink) 62%, var(--mist));
    transition: color var(--dur-hover) var(--ease);
  }
  .partner__name::after {
    content: ''; display: block; height: 1px; margin-top: 0.25rem;
    background: var(--accent-text); transform: scaleX(0); transform-origin: center;
    transition: transform var(--dur-hover) var(--ease);
  }
  .partner__note { font-family: var(--mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--mist); }
  .partner:hover .partner__name, .partner:focus-visible .partner__name { color: var(--accent-text); }
  .partner:hover .partner__name::after, .partner:focus-visible .partner__name::after { transform: scaleX(1); }
  .partner:focus-visible { outline: none; }

  @media (prefers-reduced-motion: reduce) {
    .marquee { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .marquee__track { animation: none; }
    .partner__name, .partner__name::after { transition: none; }
  }
</style>
