---
import { partners } from '@data/partners';
---
<section class="section-tight fill partners-sec">
  <div class="wrap">
    <p class="eyebrow partners__eyebrow reveal">The tools we trust</p>
    <ul class="partners reveal">
      {partners.map((p) => (
        <li class="partner" title={p.note}>
          <span class="partner__name">{p.name}</span>
          <span class="partner__note">{p.note}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .partners-sec { padding-block: var(--space-m); }
  .partners__eyebrow { text-align: center; margin-bottom: 1.6rem; }
  .partners {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1px; background: var(--line);
    border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden;
  }
  .partner {
    display: grid; gap: 0.25rem; place-content: center; text-align: center;
    background: var(--white-pure); padding: 1.4rem 1rem; min-height: 92px;
    transition: background var(--dur-hover) var(--ease);
  }
  .partner:hover { background: var(--paper); }
  .partner__name {
    font-family: var(--display); font-size: var(--step-1); line-height: 1.1;
    color: color-mix(in srgb, var(--ink) 78%, var(--mist));
  }
  .partner:hover .partner__name { color: var(--ink); }
  .partner__note { font-family: var(--mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--mist); }
  @media (max-width: 760px) { .partners { grid-template-columns: repeat(2, 1fr); } }
</style>
